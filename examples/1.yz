let x = -5;
let f = "ffafafkihujyfdersrfedui";

func main(param, other_param) {
    println("inside the function!");
}

func other() {
    println("other");
}

if x == f {
    println("x equals f (impossible)");
}

if x == x {
    println("x equals x!");
}

println(x);
let y = x + 6 * 4;
println(y);
let z = y * 44 + 3;
println(z);

other();
main();