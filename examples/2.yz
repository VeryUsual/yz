import stdlib;

let x = "32";
let x = int(val x);

func main(param, other_param) {
    println(x);

    let i = -5;
    while i < 20 {
        println(i);
        let i = i + 1;
        if i > 5 {
            break;
        }
    }

    return i;
}

let y = main(param 5, other_param "32");
println(y);